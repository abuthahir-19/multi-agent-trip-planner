# ============================================================
# Multi-Agent Trip Planner — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys

# LLM Provider — set ONE of these (Anthropic preferred; OpenAI supported as fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: OpenWeatherMap (free tier available at openweathermap.org)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Optional: Google APIs (for real places/routes)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional: Redis (for session memory — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Optional: Travel APIs (system uses smart mock data if not set)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# App settings
DEBUG=false
OUTPUT_DIR=output
