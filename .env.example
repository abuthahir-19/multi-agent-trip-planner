# ============================================================
# Multi-Agent Trip Planner — Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================

# ── Required ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Real-time Hotels + Flights (RapidAPI) ────────────────────
# Sign up free at https://rapidapi.com
# Subscribe to:  "Booking.com" API  +  "Skyscanner Flight Search" API
# Both use the same key below.
# Without this key the app uses smart mock data automatically.
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Weather (free tier) ───────────────────────────────────────
# Sign up free at https://openweathermap.org → "API Keys" tab
OPENWEATHER_API_KEY=your_openweathermap_key_here

# ── Optional: Google APIs ─────────────────────────────────────
# console.cloud.google.com → Enable "Places API" + "Maps JavaScript API"
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
GOOGLE_PLACES_API_KEY=your_google_places_key_here

# ── Optional: Amadeus (flight data, test env is free) ─────────
# developers.amadeus.com → Self-Service → create app → copy keys
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ── Optional: Redis session store ────────────────────────────
# Falls back to in-memory dict if not set
REDIS_URL=redis://localhost:6379

# ── App settings ─────────────────────────────────────────────
OUTPUT_DIR=output
DEBUG=false
